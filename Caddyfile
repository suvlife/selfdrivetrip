# SelfDriveTrip Caddyfile
# Routes:
#   trip.guofeng.me - Frontend (Vue/React SPA)
#   api-trip.guofeng.me/api/* - Backend API

# Backend API - api-trip.guofeng.me
api-trip.guofeng.me {
    reverse_proxy /api/* selfdrivetrip-backend:8000
    reverse_proxy /docs selfdrivetrip-backend:8000
    reverse_proxy /openapi.json selfdrivetrip-backend:8000

    header /api/* {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
    }
}

# Frontend - trip.guofeng.me
trip.guofeng.me {
    root * /var/www/selfdrivetrip/frontend
    file_server
    try_files {path} /index.html

    header /assets/* {
        Cache-Control "public, max-age=31536000, immutable"
    }
}
