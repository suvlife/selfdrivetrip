# SelfDriveTrip Backend Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://selfdrivetrip:password@postgres:5432/selfdrivetrip

# AI / LLM (new-api at api.learnclub.ai)
AI_API_KEY=your-new-api-key-here
AI_API_BASE_URL=https://api.learnclub.ai/v1
AI_MODEL=deepseek-chat

# AMap (高德开放平台) - https://lbs.amap.com/
AMAP_KEY=your-amap-api-key-here

# Unsplash - https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-api-key-here

# OpenWeatherMap - https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://go.suv.life
